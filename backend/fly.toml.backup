app = "app-doufonzs"
primary_region = "iad"

[build]
  builder = "paketobuildpacks/builder:base"

[env]
  PORT = "8000"
  PYTHON_ENABLE_GC = "true"
  PYTHON_GC_THRESHOLD = "50"  # Even lower threshold for more frequent garbage collection
  PYTHON_OPTIMIZE = "2"
  OPENAI_API_KEY = "your-openai-api-key"
  ENTREZ_EMAIL = "your-email@example.com"
  ENTREZ_API_KEY = "your-entrez-api-key"
  MAX_ARTICLES = "5"  # Limit number of articles to reduce memory usage

[http_service]
  internal_port = 8000
  force_https = true
  auto_stop_machines = true
  auto_start_machines = true
  min_machines_running = 0
  processes = ["app"]
  [http_service.concurrency]
    type = "connections"
    hard_limit = 10  # Reduced from 25
    soft_limit = 5   # Reduced from 20

[processes]
  app = "uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 1 --limit-concurrency 2 --timeout-keep-alive 15"

[[vm]]
  memory = "8gb"  # Increased from 4gb
  cpu_kind = "shared"
  cpus = 2
